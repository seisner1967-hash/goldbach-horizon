/-
  Goldbach/A2CertificateData.lean
  Breakpoint data for the A2 self-adjointness certificate.

  Contains the 1229 primes up to 9973 and their log enclosure precision.
-/
import Mathlib.Data.Rat.Basic
import Mathlib.Data.List.Basic

namespace Goldbach

/-- Precision: 10^9. All log enclosures use denominator 10^9. -/
def breakpointPrec : ℕ := 10^9

/-- A breakpoint enclosure: (prime, lo_numerator, hi_numerator).
    Encodes: lo_num/10^9 < log(prime) < hi_num/10^9. -/
structure BreakpointEnclosure where
  prime : ℕ
  lo_num : ℕ
  hi_num : ℕ
  deriving Repr, DecidableEq

